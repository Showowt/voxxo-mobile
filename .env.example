# Voxxo Mobile Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase (get from https://app.supabase.com/project/YOUR_PROJECT/settings/api)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Translation API (Voxxo backend)
EXPO_PUBLIC_TRANSLATION_API_URL=https://voxlink-v14.vercel.app/api/translate
